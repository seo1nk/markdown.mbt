{
  "name": "@mizchi/markdown",
  "version": "0.6.4",
  "type": "module",
  "description": "incremental markdown parser",
  "scripts": {
    "build:moon": "moon build --target js --release",
    "build:editor": "pnpm run build:moon && tsc -p tsconfig.editor.json && node scripts/prepare-editor-package.mjs",
    "bench:literal": "node --experimental-strip-types e2e/literal-benchmark.ts",
    "bench:literal:core": "moon bench --target js -p mizchi/markdown -f bench_renderer_literal.mbt",
    "prepublishOnly": "pnpm run build:editor",
    "build:dist": "pnpm run build:moon && vite build --base ./ --outDir ../dist-playground --emptyOutDir && node scripts/build-dist-lib.mjs",
    "deploy:works": "pnpm run build:dist && node scripts/stage-deploy.mjs && wrangler deploy -c wrangler.works.jsonc",
    "test": "vitest run"
  },
  "imports": {
    "#moonbit/highlight-typescript": "./_build/js/release/build/mizchi/markdown/highlight_typescript/highlight_typescript.js",
    "#moonbit/highlight-moonbit": "./_build/js/release/build/mizchi/markdown/highlight_moonbit/highlight_moonbit.js",
    "#moonbit/highlight-json": "./_build/js/release/build/mizchi/markdown/highlight_json/highlight_json.js",
    "#moonbit/highlight-html": "./_build/js/release/build/mizchi/markdown/highlight_html/highlight_html.js",
    "#moonbit/highlight-css": "./_build/js/release/build/mizchi/markdown/highlight_css/highlight_css.js",
    "#moonbit/highlight-bash": "./_build/js/release/build/mizchi/markdown/highlight_bash/highlight_bash.js",
    "#moonbit/highlight-rust": "./_build/js/release/build/mizchi/markdown/highlight_rust/highlight_rust.js"
  },
  "exports": {
    ".": {
      "import": "./js/api.js",
      "types": "./js/api.d.ts"
    },
    "./editor": {
      "import": "./dist/frontend/editor/index.js",
      "types": "./dist/frontend/editor/index.d.ts"
    },
    "./editor/literal": {
      "import": "./dist/frontend/editor/literal.js",
      "types": "./dist/frontend/editor/literal.d.ts"
    },
    "./editor/style.css": "./dist/frontend/editor/style.css",
    "./editor/overlay.css": "./dist/frontend/editor/overlay.css",
    "./highlight": {
      "import": "./dist/frontend/highlight/index.js",
      "types": "./dist/frontend/highlight/index.d.ts"
    },
    "./highlight/typescript": {
      "import": "./dist/frontend/highlight/languages/typescript.js",
      "types": "./dist/frontend/highlight/languages/typescript.d.ts"
    },
    "./highlight/moonbit": {
      "import": "./dist/frontend/highlight/languages/moonbit.js",
      "types": "./dist/frontend/highlight/languages/moonbit.d.ts"
    },
    "./highlight/json": {
      "import": "./dist/frontend/highlight/languages/json.js",
      "types": "./dist/frontend/highlight/languages/json.d.ts"
    },
    "./highlight/html": {
      "import": "./dist/frontend/highlight/languages/html.js",
      "types": "./dist/frontend/highlight/languages/html.d.ts"
    },
    "./highlight/css": {
      "import": "./dist/frontend/highlight/languages/css.js",
      "types": "./dist/frontend/highlight/languages/css.d.ts"
    },
    "./highlight/bash": {
      "import": "./dist/frontend/highlight/languages/bash.js",
      "types": "./dist/frontend/highlight/languages/bash.d.ts"
    },
    "./highlight/rust": {
      "import": "./dist/frontend/highlight/languages/rust.js",
      "types": "./dist/frontend/highlight/languages/rust.d.ts"
    },
    "./dist-lib/api": "./dist-lib/api.js",
    "./dist-lib/chord-language": "./dist-lib/chord_language.js",
    "./dist-lib/chord-widget": "./dist-lib/chord-widget.js"
  },
  "keywords": [
    "markdown",
    "moonbit"
  ],
  "author": "mizchi <miz404@gmail.com>",
  "license": "MIT",
  "packageManager": "pnpm@10.23.0",
  "peerDependencies": {
    "@luna_ui/luna": "^0.11.0"
  },
  "peerDependenciesMeta": {
    "@luna_ui/luna": {
      "optional": true
    }
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@luna_ui/luna": "^0.11.0",
    "@playwright/test": "^1.58.2",
    "@types/mdast": "^4.0.4",
    "@types/unist": "^3.0.3",
    "axe-core": "^4.11.4",
    "esbuild": "^0.28.1",
    "playwright": "^1.58.2",
    "preact": "^10.28.4",
    "puppeteer": "^24.38.0",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "remark-html": "^16.0.1",
    "remark-stringify": "^11.0.0",
    "typescript": "^5.9.3",
    "unified": "^11.0.5",
    "vite": "^7.3.1",
    "vite-plugin-moonbit": "0.1.5",
    "vitest": "^4.0.18",
    "wrangler": "^4.81.1"
  },
  "files": [
    "js/api.js",
    "js/api.d.ts",
    "dist/frontend",
    "_build/js/release/build/mizchi/markdown/api/api.js",
    "_build/js/release/build/mizchi/markdown/api/api.d.ts",
    "_build/js/release/build/mizchi/markdown/api/moonbit.d.ts",
    "_build/js/release/build/mizchi/markdown/highlight_typescript/highlight_typescript.js",
    "_build/js/release/build/mizchi/markdown/highlight_typescript/highlight_typescript.d.ts",
    "_build/js/release/build/mizchi/markdown/highlight_typescript/moonbit.d.ts",
    "_build/js/release/build/mizchi/markdown/highlight_moonbit/highlight_moonbit.js",
    "_build/js/release/build/mizchi/markdown/highlight_moonbit/highlight_moonbit.d.ts",
    "_build/js/release/build/mizchi/markdown/highlight_moonbit/moonbit.d.ts",
    "_build/js/release/build/mizchi/markdown/highlight_json/highlight_json.js",
    "_build/js/release/build/mizchi/markdown/highlight_json/highlight_json.d.ts",
    "_build/js/release/build/mizchi/markdown/highlight_json/moonbit.d.ts",
    "_build/js/release/build/mizchi/markdown/highlight_html/highlight_html.js",
    "_build/js/release/build/mizchi/markdown/highlight_html/highlight_html.d.ts",
    "_build/js/release/build/mizchi/markdown/highlight_html/moonbit.d.ts",
    "_build/js/release/build/mizchi/markdown/highlight_css/highlight_css.js",
    "_build/js/release/build/mizchi/markdown/highlight_css/highlight_css.d.ts",
    "_build/js/release/build/mizchi/markdown/highlight_css/moonbit.d.ts",
    "_build/js/release/build/mizchi/markdown/highlight_bash/highlight_bash.js",
    "_build/js/release/build/mizchi/markdown/highlight_bash/highlight_bash.d.ts",
    "_build/js/release/build/mizchi/markdown/highlight_bash/moonbit.d.ts",
    "_build/js/release/build/mizchi/markdown/highlight_rust/highlight_rust.js",
    "_build/js/release/build/mizchi/markdown/highlight_rust/highlight_rust.d.ts",
    "_build/js/release/build/mizchi/markdown/highlight_rust/moonbit.d.ts"
  ]
}